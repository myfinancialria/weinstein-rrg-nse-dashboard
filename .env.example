FYERS_CLIENT_ID=your_fyers_client_id
FYERS_ACCESS_TOKEN=your_fyers_access_token

# Optional pre-open input for the daily Market Blog tab.
# Use a manual value when a stable public GIFT Nifty feed is unavailable.
GIFT_NIFTY_LEVEL=

# Optional Yahoo Finance symbol if you have a working GIFT Nifty proxy.
GIFT_NIFTY_SYMBOL=
